# Server
PORT=4000

# Pinata (https://app.pinata.cloud) - free tier is enough for a prototype
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_API_KEY=your_pinata_secret_key
# Alternative: PINATA_JWT=your_pinata_jwt   (if using JWT auth instead of key/secret)

# Blockchain (read-only lookups from backend; write txs happen from the
# frontend via MetaMask so institute/verifier keys never touch the server)
RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id
CONTRACT_ADDRESS=0xDeployedContractAddressHere
