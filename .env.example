# Used by hardhat.config.js and scripts/deploy.js

# RPC endpoint for a testnet, e.g. Sepolia via Infura/Alchemy:
RPC_URL=https://sepolia.infura.io/v3/your_infura_project_id

# Private key of the deployer wallet (needs a little Sepolia test ETH from a faucet)
PRIVATE_KEY=your_deployer_wallet_private_key

# Optional: auto-grant roles right after deployment
ISSUER_ADDRESS=0xInstituteWalletAddress
VERIFIER_ADDRESS=0xVerifierWalletAddress
